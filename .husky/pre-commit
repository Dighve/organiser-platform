#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Check if we're in the frontend directory
if [ -d "frontend" ]; then
  cd frontend
  
  echo "📦 Checking frontend..."
  
  # Run linter
  echo "  → Running ESLint..."
  npm run lint --silent || {
    echo "❌ ESLint failed. Please fix linting errors before committing."
    exit 1
  }
  
  # Check for console.log in staged files
  echo "  → Checking for console.log statements..."
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.jsx\?$" | grep -v "analytics.js" || true)
  if [ ! -z "$STAGED_FILES" ]; then
    for FILE in $STAGED_FILES; do
      if grep -q "console\.log" "$FILE"; then
        echo "❌ Found console.log in $FILE"
        echo "   Please remove console.log statements before committing."
        exit 1
      fi
    done
  fi
  
  # Check for debugger statements
  echo "  → Checking for debugger statements..."
  if [ ! -z "$STAGED_FILES" ]; then
    for FILE in $STAGED_FILES; do
      if grep -q "debugger" "$FILE"; then
        echo "❌ Found debugger statement in $FILE"
        exit 1
      fi
    done
  fi
  
  cd ..
fi

# Check if we're in the backend directory
if [ -d "backend" ]; then
  cd backend
  
  echo "☕ Checking backend..."
  
  # Check for System.out.println
  echo "  → Checking for System.out.println..."
  STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.java$" || true)
  if [ ! -z "$STAGED_JAVA_FILES" ]; then
    for FILE in $STAGED_JAVA_FILES; do
      if grep -q "System\.out\.println" "$FILE"; then
        echo "❌ Found System.out.println in $FILE"
        echo "   Please use proper logging (slf4j) instead."
        exit 1
      fi
    done
  fi
  
  cd ..
fi

echo "✅ Pre-commit checks passed!"
