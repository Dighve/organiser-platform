#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Get all staged files from repo root
STAGED_JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^frontend/src/.*\.jsx\?$" || true)
STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^backend/.*\.java$" || true)

# Check frontend
if [ ! -z "$STAGED_JS_FILES" ]; then
  echo "📦 Checking frontend..."
  
  # Note: ESLint runs in CI/CD pipeline, skipping here to avoid config issues
  
  # Check for console.log in staged files (exclude analytics.js)
  echo "  → Checking for console.log statements..."
  for FILE in $STAGED_JS_FILES; do
    if echo "$FILE" | grep -q "analytics.js"; then
      continue
    fi
    if grep -q "console\.log" "$FILE"; then
      echo "❌ Found console.log in $FILE"
      echo "   Please remove console.log statements before committing."
      exit 1
    fi
  done
  
  # Check for debugger statements
  echo "  → Checking for debugger statements..."
  for FILE in $STAGED_JS_FILES; do
    if grep -q "debugger" "$FILE"; then
      echo "❌ Found debugger statement in $FILE"
      exit 1
    fi
  done
fi

# Check backend
if [ ! -z "$STAGED_JAVA_FILES" ]; then
  echo "☕ Checking backend..."
  
  # Check for System.out.println
  echo "  → Checking for System.out.println..."
  for FILE in $STAGED_JAVA_FILES; do
    if grep -q "System\.out\.println" "$FILE"; then
      echo "❌ Found System.out.println in $FILE"
      echo "   Please use proper logging (slf4j) instead."
      exit 1
    fi
  done
fi

echo "✅ Pre-commit checks passed!"
